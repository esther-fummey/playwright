// await page.getByLabel('First name').fill('John');
// await page.getByPlaceholder('Username').fill('standard_user');
// await page.getByText('Next').click();
//
// Why use these? They match the accessibility tree, so your tests are resilient
// to HTML structure changes. Your tests literally test what users see!
//
// Example from real test:
// await page.getByRole('button', { name: 'Login' }).click();
// await page.getByRole('textbox', { name: 'Password' }).fill('secret_sauce');
//
// PRIORITY 2: CSS Selectors
// ================
// await page.locator('.my-class').click();                    // Class selector
// await page.locator('#my-id').fill('text');                  // ID selector
// await page.locator('button.primary').click();               // Combining selectors
// await page.locator('css=button:visible').click();           // CSS keyword syntax
// await page.locator('css=button:visible').first().click();   // First match
//
// Example from real test:
// await page.locator('#user-name').fill('standard_user');
// await page.locator('#password').fill('secret_sauce');
// await page.locator('#login-button').click();
//
// PRIORITY 3: XPath (Use sparingly - breaks easily!)
// ================
// await page.locator('//div[@id="xpath"]').click();           // XPath syntax
// await page.locator('//button[text()="Login"]').click();     // XPath with text
//
// Avoid XPath when possible - it's fragile and hard to maintain.

