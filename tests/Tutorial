// =====================================================================
// 7. ANNOTATIONS (CONTROLLING TEST BEHAVIOR)
// =====================================================================
//
// test.skip()
// Completely ignores the test (it won't run at all)
// Use when: Feature is temporarily disabled or under development
//
// test('this test will not run', async ({ page }) => {
//     test.skip();
//     // code here is ignored
// });
//
// Conditional skip (skip only in specific browser):
// test('skip in firefox', async ({ page, browserName }) => {
//     test.skip(browserName === 'firefox', 'Feature not supported on Firefox');
// });
//
// test.fail()
// Marks a test as "expected to fail". If it actually passes, Playwright flags it as an error!
// Use when: You know there's a bug but want to document it
//
// test.fail('test expected to fail because of Bug #123', async ({ page }) => {
//     // Test code that currently fails
// });
//
// test.fixme()
// Like skip(), but marks the test as needing developer attention
// Use when: The test itself is broken and needs to be rewritten
//
// test.fixme('test needs to be rewritten', async ({ page }) => {
//     // broken code
// });
//
// test.slow()
// Triples the default timeout for this specific test
// Use when: Test does heavy processing, file uploads, or complex flows
//
// test('a very long checkout flow', async ({ page }) => {
//     test.slow();
//     // Long running code - will have 90 seconds instead of 30 seconds
// });
//
// test.step()
// Breaks a test into named steps for better HTML reporting and debugging
// Use when: You have a multi-step test that benefits from clear sections
//
// test('Login and checkout', async ({ page }) => {
//     await test.step('Login to the application', async () => {
//         await page.locator('#username').fill('user');
//         await page.locator('#password').fill('pass');
//         await page.locator('#login').click();
//     });
//     await test.step('Add item to cart', async () => {
//         await page.locator('.add-to-cart').click();
//     });
// });
//
// Example from real test:
// test.fail('test1', async ({ page }) => {
//     // This test is marked as expected to fail
// });

// =====================================================================
// 8. TAGS & GREP (RUNNING SPECIFIC TESTS)
// =====================================================================
//
// test('My Test', { tag: '@smoke' }, async ({ page }) => { ... })
//
// Tags allow you to categorize tests and run subsets from CLI:
// npx playwright test --grep "@smoke"                    // Run only @smoke tests
// npx playwright test --grep "@smoke|@regression"        // Run @smoke OR @regression
// npx playwright test --grep-invert "@api"               // Run everything EXCEPT @api
// npx playwright test -g "Login Tests"                   // Run tests matching pattern
//
// Tips:
// - Use @smoke for quick sanity checks
// - Use @regression for full test suite
// - Use @slow for long-running tests
// - Use @api for tests that call external APIs

// =====================================================================
// 9. CLI COMMANDS (RUNNING TESTS)
// =====================================================================
//
// BASIC COMMANDS:
// npx playwright test                        // Run all tests (headless mode)
// npx playwright test --headed               // Run tests in headed mode (see the browser!)
// npx playwright test --ui                   // Open Playwright UI mode (best for debugging!)
// npx playwright test --debug                // Pause execution in Playwright Inspector
// npx playwright test filename.spec.ts       // Run specific file
// npx playwright test filename.spec.ts:10    // Run test at exactly line 10 in that file
// npx playwright test --last-failed          // Re-run only failed tests from last run
//
// BROWSER-SPECIFIC COMMANDS:
// npx playwright test --project=chromium     // Run only on Chrome
// npx playwright test --project=firefox      // Run only on Firefox
// npx playwright test --project=webkit       // Run only on Safari
// npx playwright test --project=webkit --headed     // Run Safari in headed mode
// npx playwright test --project=chromium --project=firefox  // Run on multiple browsers
//
// FILTER COMMANDS:
// npx playwright test --grep "@smoke"        // Run tests matching pattern
// npx playwright test --grep-invert "@slow"  // Skip tests matching pattern
//
// DEBUGGING COMMANDS:
// npx playwright test --headed --debug       // Headed + Inspector = perfect for debugging
// npx playwright test --update-snapshots     // Update screenshot/snapshot comparisons

