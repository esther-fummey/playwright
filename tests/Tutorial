// =====================================================================
// 14. CONFIGURATION (playwright.config.ts)
// =====================================================================
//
// Key settings you should know:
// testDir: './tests'                    // Where your test files are
// fullyParallel: true                   // Run all tests in parallel (faster)
// retries: 1                            // Retry failed tests once
// workers: undefined                    // Number of parallel workers (default uses available cores)
// reporter: 'html'                      // Generate HTML report
// trace: 'on-first-retry'               // Record trace when test fails on first attempt
// headless: true                        // Run in headless mode
// viewport: { width: 1440, height: 713 }  // Browser window size
//
// Example project setup:
// projects: [
//     {
//         name: 'chromium',
//         use: { ...devices['Desktop Chrome'], headless: true },
//     },
//     {
//         name: 'firefox',
//         use: { ...devices['Desktop Firefox'] },
//     },
// ]

// =====================================================================
// 15. CONCEPTS & TERMINOLOGY
// =====================================================================
//
// Headless mode    : Tests run in background without showing browser window (faster)
// Headed mode      : Browser window is visible so you can watch tests (slower, better for debugging)
// Retries          : How many times Playwright auto-retries a failed test
// Workers          : How many tests run simultaneously in parallel
// Fixtures         : Reusable setup/teardown code (page, browser, context)
// Trace            : Records a video-like trace of the test execution for debugging
// TestInfo         : Object containing metadata about current test run (e.g., test.retry)
//
// Example using TestInfo:
// test('has title', async ({ page }, TestInfo) => {
//     if(TestInfo.retry) {
//         // This is a retry, do something different?
//     }
//     await page.goto('https://playwright.dev/');
//     await expect(page).toHaveTitle(/Playwright/);
// });

// =====================================================================
// 16. BEST PRACTICES SUMMARY
// =====================================================================
//
// ✅ DO:
// - Use getByRole, getByLabel, getByText for locators (user-centric)
// - Use .fill() to input text (not .type())
// - Group related tests with test.describe()
// - Use test.step() to break complex tests into readable steps
// - Run tests in --ui mode to debug
// - Use --headed when debugging flaky tests
// - Test what users see and interact with, not HTML structure
// - Use meaningful test names that describe what you're testing
//
// ❌ DON'T:
// - Use XPath (it's fragile - breaks with small HTML changes)
// - Use .type() for text input (.fill() is better)
// - Create massive tests (keep tests focused and independent)
// - Rely on page.pause() in production tests (debug-only!)
// - Use generic names like "test1" or "test 2"
// - Test implementation details, test user behavior

