// =====================================================================
// 1. SETUP & IMPORTS
// =====================================================================
// import { test, expect } from "@playwright/test";
//
// These are the two core imports needed for any Playwright test:
// - test: The test function to write your tests
// - expect: The assertion library to verify your test results

// =====================================================================
// 2. BASIC TEST STRUCTURE & NAVIGATION
// =====================================================================
//
// test('Test Name', async ({ page }) => {
//     await page.goto('https://www.example.com');  // Navigate to a URL
//     await page.pause();                          // Manually pause the test here for debugging
//     // test logic...
// });
//
// The page object is passed by Playwright automatically and contains all navigation
// and interaction methods. Always use 'async/await' because Playwright is async.

// =====================================================================
// 3. FINDING ELEMENTS (LOCATORS) - MOST IMPORTANT!
// =====================================================================
//
// PRIORITY 1: User-Centric Locators (BEST PRACTICE - Use these!)
// ================
// await page.getByRole('button', { name: 'Login' }).click();
// await page.getByRole('textbox', { name: 'Username' }).fill('standard_user');
