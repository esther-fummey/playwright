// =====================================================================
// 19. FIXTURES & CUSTOM FIXTURES
// =====================================================================
// Playwright fixtures let you share setup/teardown across tests. Use a
// `fixtures.ts` file to declare reusable fixtures such as a pre-logged-in
// page, API setup, or test data. Example:
// import { test as base } from '@playwright/test';
// import { PageManager } from './pageObjects/PageManager';
// export const test = base.extend<{ pm: PageManager }>({
//   pm: async ({ page }, use) => {
//     const pm = new PageManager(page);
//     await use(pm);
//   }
// });
// Then in tests: `test('...', async ({ pm }) => { await pm.loginPage().login(...); })`

